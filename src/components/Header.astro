---
import '../styles/global.css';
---

<header class="sticky top-0 z-50 bg-white dark:bg-gray-900 shadow">
    <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
        <!-- Logo -->
        <div class="flex lg:flex-1">
            <a href="/" class="-m-1.5 p-1.5">
                <span class="sr-only">Perrhijos y Gathijos</span>
                <img class="h-auto w-30" src="/logo.svg" alt="" />
            </a>
        </div>
        <!-- Mobile menu button -->
        <div class="flex lg:hidden">
            <button type="button" command="show-modal" commandfor="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 dark:text-gray-400">
                <span class="sr-only">Open main menu</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
        </div>
        <!-- Desktop menu -->
        <el-popover-group class="hidden lg:flex lg:gap-x-12">
            <a href="/" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Inicio</a>
            <a href="/" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Conócelos</a>
            <a href="/" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Refugios</a>
            <a href="/" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Adopción</a>
            <a href="/about" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Sobre nosotros</a>
        </el-popover-group>
        <div class="hidden lg:flex lg:flex-1 lg:justify-end">
            <a href="#" class="text-sm/6 font-semibold text-gray-900 dark:text-white">
                Iniciar sesión
                <span aria-hidden="true">&rarr;</span>
            </a>
        </div>
    </nav>
</header>