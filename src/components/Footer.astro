---
import Envelope from 'phosphor-astro/EnvelopeSimple.astro';
import Instagram from 'phosphor-astro/InstagramLogo.astro';
---
<div id="Footer" class="bg-background-2">
    <div class="flex flex-col xl:flex-row justify-center">
        <div id="footer-identity" class="flex-1 align-middle py-4">
            <img class="h-auto w-10 py-5 lg:inline-block" src="/icon-paw-64.png" alt="" />
            <a class="lg:text-4xl text-3xl font-black tracking-tighter font-anek" href="/">
                Perrhijos & Gathijos
            </a>
        </div>
        <div id="footer-contacto" class="flex-1 py-4">
            <h3 class="text-2xl font-black tracking-tighter font-anek">
                Contacto
            </h3>
            <p class="text-gray-700 text-base font-sans inline-flex items-center gap-2">
                <Envelope class="size-5" />
                <a href="mailto:perrhijosygathijos.gt@outlook.es">perrhijosygathijos.gt@outlook.es</a>
            </p>
        </div>
        <div id="footer-social" class="flex-1 py-4">
            <h3 class="text-2xl font-black tracking-tighter font-anek">
                Social
            </h3>
            <ul>
                <li>
                    <a href="https://www.instagram.com/perrhijosygathijos.gt" class="inline-flex items-center gap-2">
                        <Instagram class="size-5" />
                        Instagram
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>