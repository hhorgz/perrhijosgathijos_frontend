---
const {title, subtitle} = Astro.props;
---
<div class="bg-background p-8">
    <h3 class="text-2xl font-light tracking-wider text-center font-sans">
        {subtitle}
    </h3>
    <h1 class="text-6xl font-extrablack tracking-tight font-anek uppercase text-center">
        {title}
    </h1>
</div>