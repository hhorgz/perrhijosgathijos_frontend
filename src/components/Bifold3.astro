---
import { Image } from "astro:assets";

const {title, title2, accent, image} = Astro.props;
---

<section class="flex flex-col lg:flex-row bg-background-2">
    <div class="flex flex-col basis-2/3">
        <Image 
            src={image} 
            alt="Fotografia de uno de nuestros animales adoptados" 
            class="h-full w-full md:max-h-[720px] object-cover" 
            width={1200}
            format="webp"
            quality="mid"
            loading="lazy"
        />
    </div>
    <div class="flex flex-col basis-1/3 justify-between items-center md:items-start lg:p-8 p-4">
        <h2 class="text-3xl md:text-5xl pb-4 font-extrabold tracking-tight font-anek uppercase text-center md:text-left">
            {title} <span class="text-background-2">{accent}</span>{title2}
        </h2>
        <div class="text-gray-700 text-lg font-mono text-center md:text-left pb-4 lg:pb-8">
            <slot name="text" class="text-lg text-gray-700"/>
        </div>
        <slot name="bottom"/>
    </div>
</section>