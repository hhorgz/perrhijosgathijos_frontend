---
import { Image } from "astro:assets";
import petImage from "../assets/chano_portrait_001.jpg"; 

const {title1, title2, picture} = Astro.props;
---

<section class="flex flex-col lg:flex-row bg-background-2">
    <div class="flex flex-col basis-1/3 justify-between items-center md:items-start border lg:p-8 p-4">
        <h2 class="text-3xl md:text-5xl pb-4 font-extrabold tracking-tight font-anek uppercase text-center md:text-left">
            {title1}
        </h2>
        <div class="text-gray-700 text-lg font-mono text-center md:text-left pb-4 lg:pb-8">
            <slot name="first-text"/>
        </div>
    </div>
    <div class="flex flex-col basis-1/3 justify-between items-center md:items-start border lg:p-8 p-4">
        <h2 class="text-3xl md:text-5xl pb-4 font-extrabold tracking-tight font-anek uppercase text-center md:text-left">
            {title2}
        </h2>
        <div class="text-gray-700 text-lg font-mono text-center md:text-left pb-4 lg:pb-8">
            <slot name="second-text"/>
        </div>
    </div>
    <div class="flex flex-col basis-1/3 border lg:order-last order-first">
        <Image 
            src={petImage} 
            alt="Fotografia de uno de nuestros animales adoptados" 
            class="h-full w-full md:max-h-[720px] object-cover" 
            height={720}
            format="webp"
            quality={85}
            loading="lazy" 
        />
    </div>
</section>